{
  "name": "@karin/logger",
  "version": "0.0.1",
  "description": "karin 日志模块 — log4js + chalk",
  "keywords": [
    "karin",
    "logger"
  ],
  "license": "MIT",
  "author": "shijin",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "checkType": "tsc"
  },
  "dependencies": {
    "chalk": "catalog:",
    "log4js": "catalog:"
  },
  "devDependencies": {
    "tsdown-config": "workspace:*"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      }
    }
  }
}
